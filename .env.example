# =============================================================================
# Staging — fill in YOUR real resource names (company laptop / gcloud auth)
# =============================================================================
#
# Auth: NO local JSON key required if you already ran:
#   gcloud auth application-default login
# or activated a service account whose key lives in Secret Manager:
#   gcloud secrets versions access latest --secret="YOUR_SECRET_NAME" > %TEMP%\sa.json
#   gcloud auth activate-service-account --key-file=%TEMP%\sa.json
#   gcloud auth application-default login
# Do NOT commit key files. Leave GOOGLE_APPLICATION_CREDENTIALS unset unless
# you intentionally point at a local temp file from Secret Manager.

# GCP project
PROJECT_ID=

# Cloud Spanner (holds brand_references + recommendation tables)
SPANNER_INSTANCE_ID=
SPANNER_DATABASE_ID=

# Pub/Sub — only for POST /v1/interaction or /v1/feedback (not needed for staging scripts)
PUBSUB_INTERACTION_TOPIC=

# Service config
ENVIRONMENT=development
RETRIEVAL_DEADLINE_SEC=0.15
EXPLORATION_RATE=0.10
